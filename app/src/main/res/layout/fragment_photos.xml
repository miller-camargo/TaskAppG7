<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Bloque 1 -->
        <LinearLayout
            android:id="@+id/bloqueFoto1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/imgBloque1"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:src="@drawable/bloque1"
                android:contentDescription="Imagen bloque 1" />

            <TextView
                android:id="@+id/txtTituloBloque1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Editar Video"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/txtDescripcionBloque1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Editar video para presentación pendiente con equipo reunión 18/04/2026"
                android:textSize="14sp"
                android:textColor="#6B7280" />
        </LinearLayout>

        <!-- Bloque 2 -->
        <LinearLayout
            android:id="@+id/bloqueFoto2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="20dp"
            android:orientation="vertical"
            android:padding="12dp"
            android:background="#FFFFFF"
            android:elevation="4dp">

            <ImageView
                android:id="@+id/imgBloque2"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:scaleType="centerCrop"
                android:src="@drawable/bloque2"
                android:contentDescription="Imagen bloque 2" />

            <TextView
                android:id="@+id/txtTituloBloque2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="Reunión con Equipo"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="#111827" />

            <TextView
                android:id="@+id/txtDescripcionBloque2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Reunión en sala de juntas, avisar por correo a requeridos y equipo Soporte"
                android:textSize="14sp"
                android:textColor="#6B7280" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>