<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F0F4F8">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tipos de Botones"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1F2937"
            android:layout_marginBottom="24dp" />

        <!-- 1. Filled -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="1. Botón Filled (Relleno)"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_filled"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Botón Filled"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="20dp" />

        <!-- 2. Outlined -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Botón Outlined (Contorno)"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_outlined"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Botón Outlined"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_marginBottom="20dp" />

        <!-- 3. Text Button -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Botón de Texto (Text Button)"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Botón de Texto"
            android:textSize="16sp"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginBottom="20dp" />

        <!-- 4. Ícono -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="4. Botón con Ícono"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_icon"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Compartir"
            android:textSize="16sp"
            app:icon="@android:drawable/ic_menu_share"
            app:iconGravity="start"
            app:iconPadding="8dp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="20dp" />

        <!-- 5. Toggle -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="5. Botón Toggle (Activar / Desactivar)"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="8dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_toggle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Activar Modo"
            android:textSize="16sp"
            app:cornerRadius="8dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tv_toggle_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado: DESACTIVADO"
            android:textSize="14sp"
            android:textColor="#EF4444"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- 6. Contador -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="6. Contador Interactivo"
            android:textSize="14sp"
            android:textColor="#6B7280"
            android:layout_marginBottom="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="8dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_decrement"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="−"
                android:textSize="24sp"
                app:cornerRadius="28dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

            <TextView
                android:id="@+id/tv_counter"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="36sp"
                android:textStyle="bold"
                android:textColor="#1F2937"
                android:gravity="center" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_increment"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="+"
                android:textSize="24sp"
                app:cornerRadius="28dp" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_reset"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Reiniciar Contador"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_marginBottom="32dp" />

    </LinearLayout>
</ScrollView>
